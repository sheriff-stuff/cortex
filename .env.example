# Meeting Notes — Docker environment variables (optional)
# Copy to .env:  cp .env.example .env
#
# Most configuration belongs in config.yaml (see config.docker.yaml).
# These env vars are only needed to override specific server.py settings.

# Database URL (overrides config.yaml)
# MEETING_NOTES_DATABASE_URL=postgresql://user:password@host:5432/meeting_notes

# LLM API key (overrides config.yaml — useful for keeping secrets out of config files)
# MEETING_NOTES_LLM_API_KEY=sk-...

# --- Port overrides (useful if defaults clash with local dev) ---
# FRONTEND_PORT=3000
# BACKEND_PORT=9000
# OLLAMA_PORT=11434
